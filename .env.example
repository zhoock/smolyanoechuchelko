# Copy to .env and fill with real values (never commit .env)

# YooKassa Payment Settings
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key

# Database
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Email
RESEND_API_KEY=your-resend-api-key

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# Supabase (frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_USE_SUPABASE_STORAGE=true

# Supabase (backend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage (одинаковое имя для Vite-сборки и Netlify Functions)
VITE_STORAGE_BUCKET_NAME=your-bucket-name
STORAGE_BUCKET_NAME=your-bucket-name

NETLIFY_SITE_URL=
USE_PROD_API=false
